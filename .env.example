# Server
PORT=8000

# Auth
# Use long random strings in real environments
secret_key=replace_me
refresh_key=replace_me

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

# Stripe (TEST MODE recommended for development)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Frontend URL for Stripe redirects (no trailing slash recommended)
CLIENT_URL=http://localhost:5173

# NOTE:
# - Do NOT commit your real .env (it contains secrets).
# - VITE_* variables belong in the frontend, not the backend.

